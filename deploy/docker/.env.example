# Kumatastic secrets for docker compose. Copy to `.env` and fill in.
# These override the matching keys in kumatastic.yaml, so you can keep secrets
# out of the mounted config file. Both are optional — leave blank to disable.

# Shared secret for DISTRIBUTED PUSH mode. Every pusher that should report to
# the SAME Uptime Kuma monitors must use the SAME value (tokens are derived
# from it via HMAC-SHA256). This is the secret you share with another operator
# so their pusher feeds your Kuma instance. Anyone with it can push status for
# any node — treat it as sensitive. Leave blank for single-instance mode.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
KUMATASTIC_SECRET=

# Bearer token authenticating collector -> pusher HTTP sighting POSTs. Set the
# SAME value on a collector and the pusher it forwards to. This is transport
# auth for the /sighting endpoint only — it has nothing to do with which Kuma
# monitors are hit. Leave blank to accept unauthenticated sightings.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
KUMATASTIC_SIGHTING_TOKEN=
