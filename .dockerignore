*.env
kumatastic.yaml
nodes.yaml
state.json
*.json.tmp
INFRA.md

# Editor / OS
.vscode/
.idea/
.DS_Store

# NOTE: README.md is intentionally NOT ignored — pyproject.toml references it
# as the long-description and pip reads it during the build.
